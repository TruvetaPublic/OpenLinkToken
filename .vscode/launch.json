{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  //
  // First-time setup: run "Setup 1" then "Setup 2" once. The consumer
  // launches below pick up the resulting exchange config and auto-discover
  // the matching private key from ~/.openlinktoken/.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Setup 1: generate-key-pair (recipient)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/lib/python/openlinktoken-cli/src/main/openlinktoken_cli/main.py",
      "env": {
        "PYTHONPATH": "lib/python/openlinktoken-cli/src/main:lib/python/openlinktoken/src/main"
      },
      "args": ["generate-key-pair", "--name", "local-recipient", "--force"]
    },
    {
      "name": "Setup 2: initiate-exchange",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/lib/python/openlinktoken-cli/src/main/openlinktoken_cli/main.py",
      "env": {
        "PYTHONPATH": "lib/python/openlinktoken-cli/src/main:lib/python/openlinktoken/src/main"
      },
      "args": [
        "initiate-exchange",
        "--public-key",
        "${env:HOME}/.openlinktoken/local-recipient.public.pem",
        "--output",
        "${workspaceFolder}/lib/python/openlinktoken-cli/target/local.exchange.json",
        "--force"
      ]
    },
    {
      "name": "Python: tokenize",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/lib/python/openlinktoken-cli/src/main/openlinktoken_cli/main.py",
      "env": {
        "PYTHONPATH": "lib/python/openlinktoken-cli/src/main:lib/python/openlinktoken/src/main"
      },
      "args": [
        "tokenize",
        "-i",
        "${workspaceFolder}/resources/sample.${input:inputType}",
        "-o",
        "${workspaceFolder}/lib/python/openlinktoken-cli/target/output.${input:outputType}",
        "--exchange-config",
        "${workspaceFolder}/lib/python/openlinktoken-cli/target/local.exchange.json",
        "--mode",
        "${input:tokenizeMode}"
      ]
    },
    {
      "name": "Python: package",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/lib/python/openlinktoken-cli/src/main/openlinktoken_cli/main.py",
      "env": {
        "PYTHONPATH": "lib/python/openlinktoken-cli/src/main:lib/python/openlinktoken/src/main"
      },
      "args": [
        "package",
        "-i",
        "${workspaceFolder}/resources/sample.${input:inputType}",
        "-o",
        "${workspaceFolder}/lib/python/openlinktoken-cli/target/output.${input:outputType}",
        "--exchange-config",
        "${workspaceFolder}/lib/python/openlinktoken-cli/target/local.exchange.json"
      ]
    },
    {
      "name": "Python: encrypt",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/lib/python/openlinktoken-cli/src/main/openlinktoken_cli/main.py",
      "env": {
        "PYTHONPATH": "lib/python/openlinktoken-cli/src/main:lib/python/openlinktoken/src/main"
      },
      "args": [
        "encrypt",
        "-i",
        "${workspaceFolder}/lib/python/openlinktoken-cli/target/output.${input:outputType}",
        "-o",
        "${workspaceFolder}/lib/python/openlinktoken-cli/target/encrypted.${input:outputType}",
        "--exchange-config",
        "${workspaceFolder}/lib/python/openlinktoken-cli/target/local.exchange.json"
      ]
    },
    {
      "name": "Python: decrypt",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/lib/python/openlinktoken-cli/src/main/openlinktoken_cli/main.py",
      "env": {
        "PYTHONPATH": "lib/python/openlinktoken-cli/src/main:lib/python/openlinktoken/src/main"
      },
      "args": [
        "decrypt",
        "-i",
        "${workspaceFolder}/lib/python/openlinktoken-cli/target/encrypted.${input:outputType}",
        "-o",
        "${workspaceFolder}/lib/python/openlinktoken-cli/target/decrypted.${input:outputType}",
        "--exchange-config",
        "${workspaceFolder}/lib/python/openlinktoken-cli/target/local.exchange.json"
      ]
    }
  ],
  "inputs": [
    {
      "id": "inputType",
      "type": "pickString",
      "description": "Select input type",
      "options": ["csv", "parquet"],
      "default": "csv"
    },
    {
      "id": "outputType",
      "type": "pickString",
      "description": "Select output type",
      "options": ["csv", "parquet"],
      "default": "csv"
    },
    {
      "id": "tokenizeMode",
      "type": "pickString",
      "description": "Select tokenize mode",
      "options": ["default", "hash-only", "demo"],
      "default": "default"
    }
  ]
}
